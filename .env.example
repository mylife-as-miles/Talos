# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
TALOS_PROJECT_KEY=demo_project_key
TALOS_INGEST_SECRET=local_ingest_secret

# Splunk HEC
SPLUNK_HEC_URL=https://localhost:8088
SPLUNK_HEC_TOKEN=replace_with_hec_token
SPLUNK_INDEX=main
SPLUNK_SOURCE=talos-sdk
SPLUNK_SOURCETYPE=talos:error

# Splunk Search / REST fallback
SPLUNK_BASE_URL=https://localhost:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=replace_with_password
SPLUNK_TOKEN=replace_with_token

# Splunk MCP
SPLUNK_MCP_MODE=enabled
SPLUNK_MCP_SERVER_URL=http://localhost:8000

# AI
AI_PROVIDER=gemini
GEMINI_API_KEY=replace_with_key
GEMINI_MODEL=gemini-3-flash-preview

# Notifications
DISCORD_WEBHOOK_URL=replace_with_discord_webhook
SLACK_WEBHOOK_URL=

# Local browser persistence
TALOS_INDEXEDDB_NAME=talos-real-data
